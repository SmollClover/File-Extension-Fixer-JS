{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "files": {
        "includes": ["**", "!**/out/**/*", "!**/test_files/**/*"]
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "formatter": {
        "enabled": true,
        "indentWidth": 4,
        "indentStyle": "space",
        "lineWidth": 128
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single"
        }
    }
}
